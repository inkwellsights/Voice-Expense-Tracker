# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Free tier: https://console.groq.com/keys
GROQ_API_KEY=

# Free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ExpenseOwl base URL. If the bot runs inside Docker on the same compose network,
# use http://expenseowl:5006. If the bot runs on the host, keep localhost.
EXPENSEOWL_URL=http://localhost:5006

# Currency symbol shown in Telegram confirmations
CURRENCY_SYMBOL=৳

# Comma-separated list of Telegram user ids allowed to use the bot.
# Get your numeric id from @userinfobot. Leave blank for "anyone".
# Example: ALLOWED_TELEGRAM_USER_IDS=111111111,222222222
ALLOWED_TELEGRAM_USER_IDS=

# Optional explicit tag map (overrides Telegram first names). Useful when two
# users share a first name. Format: USER_TAGS=<id>:<tag>,<id>:<tag>
# Example: USER_TAGS=111111111:Saif,222222222:Aisha
USER_TAGS=

# Tier 3: send voice notes straight to Gemini (audio-in, JSON out) instead of
# routing through Whisper first. Single API call, better Banglish + income
# detection, falls back to Whisper+Gemini-text on failure. Default true.
# Flip to false to revert to the Whisper-first pipeline.
USE_AUDIO_NATIVE_GEMINI=true
