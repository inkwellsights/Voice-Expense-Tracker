# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Free tier: https://console.groq.com/keys
GROQ_API_KEY=

# Free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ExpenseOwl base URL. If the bot runs inside Docker on the same compose network,
# use http://expenseowl:5006. If the bot runs on the host, keep localhost.
EXPENSEOWL_URL=http://localhost:5006

# User-facing dashboard URL shown in /help. Distinct from EXPENSEOWL_URL
# (which is the bot's internal API endpoint). Set this to the public/LAN URL
# users would actually paste in a browser. Optional — leave blank to hide
# the dashboard link in /help.
# Example: DASHBOARD_URL=https://expenses.example.com
DASHBOARD_URL=

# Currency symbol shown in Telegram confirmations
CURRENCY_SYMBOL=৳

# Static allowlist of Telegram user ids — read at startup, can't be removed
# at runtime (you'd edit this and rebuild). Get an id from @userinfobot.
# Leave blank for "anyone" (open mode, only safe during initial setup).
# Example: ALLOWED_TELEGRAM_USER_IDS=111111111,222222222
ALLOWED_TELEGRAM_USER_IDS=

# Admin allowlist — users who can run /allow, /revoke, /users to manage the
# runtime allowlist from inside Telegram. If blank, falls back to the static
# ALLOWED list above (i.e. anyone in .env can admin). Dynamically-added users
# (via /allow) are never automatic admins.
# Example: ADMIN_TELEGRAM_USER_IDS=111111111
ADMIN_TELEGRAM_USER_IDS=

# Optional explicit tag map (overrides Telegram first names). Useful when two
# users share a first name. Format: USER_TAGS=<id>:<tag>,<id>:<tag>
# Example: USER_TAGS=111111111:Saif,222222222:Aisha
USER_TAGS=

# Tier 3: send voice notes straight to Gemini (audio-in, JSON out) instead of
# routing through Whisper first. Single API call, better Banglish + income
# detection, falls back to Whisper+Gemini-text on failure. Default true.
# Flip to false to revert to the Whisper-first pipeline.
USE_AUDIO_NATIVE_GEMINI=true

# NOTE: the `expense-proxy` service no longer reads any env vars beyond
# EXPENSEOWL_URL — it injects a client-side tag-filter dropdown into
# every dashboard page and is otherwise a pure pass-through. (Earlier
# versions had an EMAIL_TO_TAG var for per-user auto-filtering by CF
# Access email; that was rolled back 2026-05-23 in favor of explicit
# user-controlled filtering.)

# Default context tag attached to every logged entry alongside the user's
# tag, when the speaker doesn't mention anything more specific. The
# dropdown filter on the dashboard will show this as one of the choices.
TAG_DEFAULT=personal

# Canonical context tags + the synonyms Gemini might hear in voice/text.
# Format: <canonical>:<syn1>|<syn2>|...,<canonical>:<syn1>|<syn2>|...
# Gemini is told about these in its system prompt; the bot also
# normalizes after the fact, so any close match collapses to the
# canonical. Synonyms are case-insensitive. Leave blank to skip
# context-tag extraction entirely (tags will just be [username]).
# Example: TAG_SYNONYMS=MHUBEXP:masnoonhubexpress|mhubexpress|masnoonhub|hub express,family:familyfund|family fund
TAG_SYNONYMS=

# Optional self-hosted Whisper endpoint (see local-whisper/ in this repo).
# When set, the bot tries this BEFORE Groq's cloud Whisper. On any failure
# (timeout, connect refused, HTTP 503 "gpu busy", 5xx) it falls back to
# Groq automatically. Empty = Groq-only. Use the Tailscale hostname so it
# works across networks.
# Example: LOCAL_WHISPER_URL=http://desktop-3090:8000/v1/audio/transcriptions
LOCAL_WHISPER_URL=
LOCAL_WHISPER_TIMEOUT_SECONDS=8

# /loan auto-hides settled loans that haven't seen any event in this many
# days. Splitwise convention is 30. Set to 0 to never hide. Entries are
# never deleted — they remain in ExpenseOwl, /report, dashboard, and the
# /loan <name> deep-dive command.
SETTLED_LOAN_VISIBLE_DAYS=30
